DATABASE_URL=sqlite:///./radar.db
APP_PASSWORD=

# Alternativa ao DATABASE_URL: cole os campos separados da aba .env do Supabase.
DB_USER=postgres.ebquviehrtidufzxqpwd
DB_PASSWORD=
DB_HOST=aws-1-us-east-2.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres

# Chave da API Gemini (Google). Usada como fonte de precos reais (busca manual e
# bot), apoio de analise/ranking e para gerar o texto dos alertas de queda de
# preco (price_alert_bot.write_alert), com o modelo Flash-Lite (free tier).
GEMINI_API_KEY=

# Chave da API OpenAI (ChatGPT). Segundo motor de busca web de tarifas,
# rodando junto com o Gemini no app e no bot de monitoramento.
OPENAI_API_KEY=
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_API_TOKEN=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=alerts@radar.local

# Acionar o monitor (GitHub Actions) na hora ao clicar em "Buscar agora".
# Sem isso, o monitor agendado (cron a cada 4h) coleta normalmente.
# GITHUB_TOKEN: Personal Access Token com escopo 'workflow' (classic) ou
#   permissao 'Actions: read/write' (fine-grained). Coloque nos secrets do Streamlit.
# GITHUB_REPO: "usuario/repositorio", ex.: Tiago84Barros/Radar-de-Passagens-Inteligentes
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_WORKFLOW=monitor-searches.yml
GITHUB_REF=main
