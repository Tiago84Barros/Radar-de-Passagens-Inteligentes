# Acionar o scraping (GitHub Actions) na hora ao clicar em "Buscar agora".
# Sem isso, o monitor agendado (cron a cada 30 min) coleta normalmente.
# GITHUB_TOKEN: Personal Access Token com escopo 'workflow' (classic) ou
#   permissao 'Actions: read/write' (fine-grained). Coloque nos secrets do Streamlit.
# GITHUB_REPO: "usuario/repositorio", ex.: Tiago84Barros/Radar-de-Passagens-Inteligentes
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_WORKFLOW=monitor.yml
GITHUB_REF=main
